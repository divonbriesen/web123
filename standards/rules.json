{
  "version": 1,
  "comment": "Layer-3 page rules consumed by the Python checker and the JS Vicunadator. Edit here only; both checkers read this file.",
  "sites": {
    "course": {
      "site_checks": [
        {
          "type": "text",
          "rule": "footer credit is Firm ©YEAR (space before ©, none after; company not mascot)",
          "pattern": "\\S ©20\\d\\d",
          "present": true
        }
      ],
      "pages": {
        "index.html": {
          "checks": [
            {
              "type": "html_all",
              "rule": "nav links to Introduction, Contract, About",
              "patterns": [
                "href=\"introduction.html\"",
                "href=\"contract.html\"",
                "href=\"about.html\""
              ]
            },
            {
              "type": "element",
              "rule": "welcome paragraph in main",
              "tag": "p",
              "within": "main",
              "min": 1
            }
          ]
        },
        "introduction.html": {
          "checks": [
            {
              "type": "heading",
              "rule": "h2 is Introduction",
              "level": 2,
              "pattern": "intro"
            },
            {
              "type": "heading",
              "rule": "h6 display name (First 'Nick' Last <divider> Mascot)",
              "level": 6,
              "pattern": "\\s[~|•·]\\s"
            },
            {
              "type": "css",
              "rule": "h6 display name styled large (and shouldn't wrap)",
              "pattern": "h6[^{]*\\{[^}]*font-size"
            },
            {
              "type": "element",
              "rule": "photo in a figure",
              "tag": "img",
              "within": "figure",
              "min": 1
            },
            {
              "type": "element",
              "rule": "caption is a figcaption",
              "tag": "figcaption",
              "within": "figure",
              "min": 1
            },
            {
              "type": "text",
              "rule": "no acknowledgment/signature sentence (doc-only item)",
              "pattern": "public document|anyone with the link|keep private",
              "present": false
            },
            {
              "type": "heading",
              "rule": "no Last, First TOC heading (doc-only item)",
              "level": 0,
              "pattern": "^[A-Z][a-zA-Z]+, [A-Z]",
              "present": false
            },
            {
              "type": "html_all",
              "rule": "bold labels before colons (current label set)",
              "patterns": [
                "Personal Background:",
                "Professional Background:",
                "Academic Background:",
                "Primary Work Computer",
                "Primary Work Location",
                "Alternate Computer",
                "Courses I['’]m Taking"
              ]
            },
            {
              "type": "element",
              "rule": "courses are a nested ordered list",
              "tag": "ol",
              "within": "li",
              "min": 1
            },
            {
              "type": "element",
              "rule": "quote in a blockquote",
              "tag": "blockquote",
              "min": 1
            },
            {
              "type": "html",
              "rule": "quote attribution starts with - or ~",
              "pattern": "<blockquote[\\s\\S]{0,500}?[-–~]\\s*[A-Za-z]",
              "present": true
            }
          ]
        },
        "contract.html": {
          "checks": [
            {
              "type": "heading",
              "rule": "h2 is Contract",
              "level": 2,
              "pattern": "contract"
            },
            {
              "type": "text_all",
              "rule": "contract language present",
              "patterns": [
                "agree to abide by the terms of the course contract",
                "von Briesen",
                "Signed",
                "20\\d\\d"
              ]
            },
            {
              "type": "text",
              "rule": "no unedited placeholders",
              "pattern": "FIRST M\\.? LAST|SEMESTER YYYY|ABC123|NAME OF CLASS",
              "present": false
            }
          ]
        },
        "about.html": {
          "checks": [
            {
              "type": "heading",
              "rule": "h2 is About",
              "level": 2,
              "pattern": "about"
            },
            {
              "type": "html",
              "rule": "links to the course hub",
              "pattern": "divonbriesen\\.github\\.io/web123",
              "present": true
            },
            {
              "type": "text_all",
              "rule": "names the course tools",
              "patterns": [
                "VS Code",
                "Emmet",
                "Filezilla|SFTP",
                "GitHub",
                "Accumulus"
              ]
            },
            {
              "type": "text_all",
              "rule": "lists the planned sites",
              "patterns": [
                "personal",
                "course site",
                "design",
                "crapp?y",
                "whimsical|product company",
                "client project"
              ]
            },
            {
              "type": "element",
              "rule": "description bullets",
              "tag": "ul",
              "min": 1
            },
            {
              "type": "element",
              "rule": "at least two paragraphs",
              "tag": "p",
              "within": "main",
              "min": 2
            }
          ]
        }
      },
      "match_dirs": [
        "itis3135",
        "web115",
        "web215",
        "web250",
        "itsc1110",
        "cis110"
      ]
    },
    "hobby": {
      "match_dirs": [
        "hobby"
      ],
      "site_checks": [
        {
          "type": "element",
          "rule": "sections act as the pages",
          "tag": "section",
          "min": 6
        },
        {
          "type": "heading",
          "rule": "h1 is the hobby name (in header)",
          "level": 1,
          "pattern": "\\S"
        },
        {
          "type": "element",
          "rule": "each section topic has an h2 (Who/What/When/Where/How/Why)",
          "tag": "h2",
          "min": 6
        },
        {
          "type": "element",
          "rule": "figures with captions in sections",
          "tag": "figcaption",
          "within": "figure",
          "min": 3
        },
        {
          "type": "html",
          "rule": "AI Prompts section (or 'only used AI for images' comment)",
          "pattern": "AI Prompts|only used AI for images",
          "present": true
        },
        {
          "type": "html",
          "rule": "italicized AI-prompt explanation with figures",
          "pattern": "<em",
          "present": true
        },
        {
          "type": "css",
          "rule": "embedded stylesheet does the styling",
          "pattern": "section",
          "present": true
        },
        {
          "type": "html",
          "rule": "nav switches sections (SPA-style)",
          "pattern": "<nav",
          "present": true
        },
        {
          "type": "html",
          "rule": "footer links to your design firm",
          "pattern": "<footer[\\s\\S]*?href=\"\\.\\./",
          "present": true
        },
        {
          "type": "html",
          "rule": "footer has validation buttons",
          "pattern": "validator|validation|jigsaw\\.w3|lint\\.page",
          "present": true
        }
      ],
      "pages": {}
    },
    "designfirm": {
      "match_pattern": "\\.[a-z]{2,4}/",
      "site_checks": [
        {
          "type": "heading",
          "rule": "h1 is the firm name",
          "level": 1,
          "pattern": "\\S"
        },
        {
          "type": "element",
          "rule": "logo next to the h1",
          "tag": "img",
          "within": "header",
          "min": 1
        },
        {
          "type": "heading",
          "rule": "h2 is the page name (Services/Home/etc.)",
          "level": 2,
          "pattern": "\\S"
        },
        {
          "type": "element",
          "rule": "paragraphs describing company and client offer",
          "tag": "p",
          "within": "main",
          "min": 2
        },
        {
          "type": "element",
          "rule": "5-10 amazing things as a list",
          "tag": "li",
          "within": "ul",
          "min": 5
        },
        {
          "type": "css",
          "rule": "non-standard bullet style",
          "pattern": "list-style",
          "present": true
        },
        {
          "type": "text",
          "rule": "contact phone number",
          "pattern": "\\(?\\d{3}\\)?[-. ]\\d{3}[-. ]\\d{4}",
          "present": true
        },
        {
          "type": "html",
          "rule": "contact email present",
          "pattern": "[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}",
          "present": true
        },
        {
          "type": "html",
          "rule": "footer 'Page created by ...' with firm name + certification",
          "pattern": "created by|designed by",
          "present": true
        },
        {
          "type": "html",
          "rule": "no links back to course pages (standalone site)",
          "pattern": "contract\\.html|introduction\\.html|about\\.html",
          "present": false
        },
        {
          "type": "css",
          "rule": "styling is embedded (single page)",
          "pattern": "\\S",
          "present": true
        }
      ],
      "pages": {}
    },
    "mascot": {
      "match_dirs": [],
      "site_checks": [
        {
          "type": "heading",
          "rule": "h1 is the mascot business name",
          "level": 1,
          "pattern": "\\S"
        },
        {
          "type": "html",
          "rule": "slogan/tagline in header or footer (em or quotes, not both)",
          "pattern": "<em|[\"“]",
          "present": true
        },
        {
          "type": "html",
          "rule": "no b/i tags — use strong/em",
          "pattern": "<b>|<i>",
          "present": false
        },
        {
          "type": "element",
          "rule": "at least 2 paragraphs on the page",
          "tag": "p",
          "within": "main",
          "min": 2
        },
        {
          "type": "element",
          "rule": "at least 1 content image on the page",
          "tag": "img",
          "within": "main",
          "min": 1
        },
        {
          "type": "html",
          "rule": "header/footer loaded from components",
          "pattern": "components/",
          "present": true
        },
        {
          "type": "html",
          "rule": "no course links (github/freecodecamp/etc.)",
          "pattern": "freecodecamp|codecademy|github\\.io|webpages\\.charlotte",
          "present": false
        },
        {
          "type": "html",
          "rule": "designer/developer credit in footer",
          "pattern": "design|develop|coded|created",
          "present": true
        },
        {
          "type": "html",
          "rule": "dynamic functionality via JS (3 pieces — verified by eye)",
          "pattern": "<script",
          "present": true
        }
      ],
      "pages": {}
    }
  }
}